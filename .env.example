# Runsheet — Environment Variables
# Copy this to .env and fill in your values

# Xero OAuth credentials (from developer.xero.com)
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here
XERO_REDIRECT_URI=https://your-app.onrender.com/callback

# Session secret (make this a long random string)
SESSION_SECRET=change_this_to_a_random_string_at_least_32_chars

# Port (Render sets this automatically)
PORT=3000
